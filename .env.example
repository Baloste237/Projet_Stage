# ==========================================================
# Environment Configuration - Copy as .env for production
# ==========================================================

# PostgreSQL Database Configuration
# ⚠️ IMPORTANT: Change these values in production!
DB_NAME=vuln_scanner
DB_USER=postgres
DB_PASSWORD=admin
DB_PORT=5433

# Backend Application Configuration
BACKEND_PORT=8081

# Environment (development, staging, production)
ENVIRONMENT=development

# ==========================================================
# PRODUCTION RECOMMENDATIONS:
# ==========================================================
# 1. Generate strong password:
#    Windows: powershell -Command "[Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((1..24 | % {[char](Get-Random -Minimum 33 -Maximum 126)})))"
#    Linux/Mac: openssl rand -base64 32
#
# 2. Use separate database user with limited privileges
#
# 3. Enable SSL for database connections
#
# 4. Use secrets management (Docker Secrets, HashiCorp Vault, etc.)
#
# 5. Set ENVIRONMENT=production
# ==========================================================
